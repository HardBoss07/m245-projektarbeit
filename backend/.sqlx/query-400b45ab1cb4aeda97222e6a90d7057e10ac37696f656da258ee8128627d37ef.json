{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            ar.id,\n            ar.session_id,\n            ar.student_id,\n            ar.attended_lessons,\n            ar.status as \"status: AttendanceStatus\"\n        FROM attendance_records ar\n        JOIN class_sessions cs ON ar.session_id = cs.id\n        WHERE ar.student_id = $1 AND cs.class_id = $2\n        ORDER BY cs.session_date DESC\n        ",
