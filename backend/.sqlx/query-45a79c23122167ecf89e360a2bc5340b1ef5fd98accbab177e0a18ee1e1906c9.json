{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            id, \n            designation, \n            file_path, \n            document_type as \"document_type: DocumentType\", \n            target_user_id as \"target_user_id: _\", \n            modified_by as \"modified_by: _\", \n            modified_at\n        FROM documents\n        WHERE document_type = 'GENERAL' OR target_user_id = $1\n        ORDER BY modified_at DESC\n        LIMIT $2 OFFSET $3\n        ",
